    "db:push": "prisma db push",
    "db:seed": "tsx src/prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.20.0",
    "axios": "^1.7.7",
    "bcryptjs": "^2.4.3",
